# Ambiente e porta da API
NODE_ENV=development
DEV_APP_PORT=3000
PROD_APP_PORT=3000

# SQL Server
DEV_DB_SERVER=localhost
DEV_DB_PORT=1433
DEV_DB_USER=sa
DEV_DB_PASSWORD=SuaSenhaForte
DEV_DB_DATABASE=QRPSI

PROD_DB_SERVER=seu-host-producao
PROD_DB_PORT=1433
PROD_DB_USER=seu-usuario-producao
PROD_DB_PASSWORD=sua-senha-producao
PROD_DB_DATABASE=QRPSI
# Para desenvolvimento local com certificado autoassinado:
DB_TRUST_CERT=true
DB_ENCRYPT=true

# JWT
JWT_SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Origens permitidas pelo CORS (uma ou mais, separadas por vírgula).
# Em dev, inclua o IP da sua máquina na Wi‑Fi para testar no celular (ex.: npm run dev -- --host no Vite).
# Ex.: FRONTEND_URL=http://localhost:5173,http://192.168.1.45:5173
FRONTEND_URL=http://localhost:5173
