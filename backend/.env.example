# Servidor
PORT=3000
NODE_ENV=development

# SQL Server
DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=SuaSenhaForte
DB_NAME=QRPSI
# Para desenvolvimento local com certificado autoassinado:
DB_TRUST_CERT=true
DB_ENCRYPT=true

# JWT
JWT_ACCESS_SECRET=troque-por-uma-chave-longa-e-aleatoria-access
JWT_REFRESH_SECRET=troque-por-uma-chave-longa-e-aleatoria-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Origens permitidas pelo CORS (uma ou mais, separadas por vírgula).
# Em dev, inclua o IP da sua máquina na Wi‑Fi para testar no celular (ex.: npm run dev -- --host no Vite).
# Ex.: FRONTEND_URL=http://localhost:5173,http://192.168.1.45:5173
FRONTEND_URL=http://localhost:5173
