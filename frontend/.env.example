# URL da API (com /api). Em dev pode ficar vazio e usar o proxy do Vite.
VITE_API_URL=

# Base usada ao montar links públicos (/responder/...).
# Deixe vazio para usar sempre o host atual (recomendado: funciona em localhost e no IP da LAN).
# Se preencher, use a mesma origem em que o admin abre o app (evite só localhost se testar no celular).
VITE_APP_PUBLIC_URL=
